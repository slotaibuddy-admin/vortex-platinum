# Backend Konfiguration
PORT=3001
NODE_ENV=production

# Datenbank (wird automatisch von Render gesetzt)
DATABASE_URL=

# Optionale Ethereum RPCs (für echte Trades)
RPC_POLYGON=[rpc.ankr.com](https://rpc.ankr.com/polygon)
RPC_ARBITRUM=[rpc.ankr.com](https://rpc.ankr.com/arbitrum)
RPC_BASE=[mainnet.base.org](https://mainnet.base.org)

# WalletConnect Project ID (optional)
WALLETCONNECT_PROJECT_ID=
